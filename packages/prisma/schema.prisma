datasource db {
    provider = "mongodb"
    url      = env("MONGODB_URL")
}

generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["debian-openssl-1.1.x"]
}

model Snapshot {
    id        String  @id @default(auto()) @map("_id") @db.ObjectId
    babybox   Babybox @relation(fields: [babyboxId], references: [id])
    babyboxId String  @db.ObjectId

    status  Int
    time    DateTime @default(now())
    version String?

    temperature SnapshotTemperatures?
    voltage     SnapshotVoltages?
}

type SnapshotTemperatures {
    outside Int
    inner   Int
    top     Int
    bottom  Int
    casing  Int
}

type SnapshotVoltages {
    in      Int
    battery Int
}

model Babybox {
    id       String          @id @default(auto()) @map("_id") @db.ObjectId
    metadata BabyboxMetadata

    name      String     @unique
    handle    String     @unique
    snapshots Snapshot[]
}

type BabyboxMetadata {
    installDate    DateTime?
    lastServisDate DateTime?
    active         Boolean   @default(true)
    notes          String?

    address BabyboxAddress?

    network BabyboxNetwork?

    components BabyboxComponents?

    contact BabyboxContact[]
}

type BabyboxAddress {
    hospitalName String?
    street       String?
    city         String?
    postcode     String?
}

enum NetworkType {
    Undefined
    VLAN
    Routing
    HospitalNetwork
    Other
}

type BabyboxNetwork {
    type NetworkType @default(Undefined)

    pc            String?
    pcMask        String?
    pcGateway     String?
    routerLAN     String?
    routerWAN     String?
    routerGateway String?
    SDSMotory     String?
    SDSTopeni     String?
    camera        String?

    notes String?
}

type BabyboxComponents {
    camera       String?
    OS           String?
    PC           String?
    panelVersion String?
}

type BabyboxContact {
    firstname String
    lastname  String
    phone     String?
    email     String?
    note      String?
}
